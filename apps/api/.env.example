DATABASE_URL="postgresql://hunterreach:secret@localhost:5432/hunterreach"
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=your-very-long-secret-key-here
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev
EMAIL_REPLY_TO=you@gmail.com
FRONTEND_URL=http://localhost:3000
PORT=4000

# ── Outreach / anti-spam sending (optional; sensible defaults in code) ───────
# EMAIL_MAX_RECIPIENTS_PER_CAMPAIGN=1500
# EMAIL_MAX_PER_DAY=2000
# EMAIL_MAX_PER_HOUR=450
# EMAIL_MAX_PER_MINUTE=35
# EMAIL_STAGGER_JITTER_MS=2500
# EMAIL_QUEUE_LIMITER_MAX=40
# EMAIL_QUEUE_LIMITER_DURATION_MS=60000
# EMAIL_QUEUE_CONCURRENCY=2

# Scheduled email resilience (DB is source of truth; queue is rebuilt on startup / periodically)
# EMAIL_OVERDUE_SCHEDULED_POLICY=immediate
#   immediate — missed sends while down are queued with delay 0 (default)
#   fail — mark overdue SCHEDULED jobs as FAILED for manual review
#   skip_queue — leave SCHEDULED in DB but do not enqueue overdue jobs
# EMAIL_SCHEDULE_RECONCILE_INTERVAL_MS=300000
#   0 = periodic reconcile off; default 300000 = every 5 minutes

# Company tracker reminder emails (poll DB for due reminders; min 5000 ms)
# COMPANY_REMINDER_SCAN_MS=60000

# Smart follow-up suggestions on contacts (company-aware; uses email job + reply data)
# FOLLOW_UP_DAYS_FIRST=3
# FOLLOW_UP_DAYS_SECOND=7
# FOLLOW_UP_DAYS_FINAL=14
# Empty = suppress follow-ups for other contacts when anyone at the same company (name) has replied:
# FOLLOW_UP_COMPANY_SUPPRESS_MIN_RATIO=
# Or set 0–1 to suppress only when replied/messaged ratio at that company is >= threshold (e.g. 0.2).

# Gmail reply detection (thread metadata; requires gmail.readonly)
# GMAIL_REPLY_SYNC_INTERVAL_MS=180000
#   0 = disable server-side periodic sync only
# GMAIL_REPLY_SYNC_MAX_JOB_AGE_DAYS=365
# GMAIL_REPLY_SYNC_INTER_THREAD_DELAY_MS=120
#   delay between thread fetches for periodic/startup sync (rate limit safety)
# GMAIL_REPLY_SYNC_MANUAL_THREAD_CONCURRENCY=4
#   parallel threads.get for manual “Sync replies” (1 = sequential)
# GMAIL_REPLY_SYNC_MANUAL_INTER_BATCH_DELAY_MS=80
#   pause after each concurrent batch during manual sync
# GMAIL_REPLY_SYNC_THREAD_BACKFILL_CONCURRENCY=5
#   parallel messages.get when resolving thread IDs
